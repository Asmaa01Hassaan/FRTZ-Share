<odoo>
    <record id="paperformat_report_stock" model="report.paperformat">
        <field name="name">Stock Report</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">50</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">50</field>
        <field name="dpi">90</field>
    </record>
    <record id="action_x_inventory_report" model="ir.actions.report">
        <field name="name">Rest Report</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">x_inventory_report.report_stock_picking_x_custom</field>
        <field name="report_file">x_inventory_report.report_stock_picking_x_custom</field>
        <field name="print_report_name">'Report - %s' % (object.name)</field>
        <field name="paperformat_id" ref="paperformat_report_stock"/>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>
    <template id="report_stock_picking_x_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <t t-set="u_lang" t-value="env.lang"/>

                    <div class="page">
                        <div class="title" style="padding: 0 0 30px 0 !important;">
                            <h1 style="text-align:center;">
                                <span t-field="o.picking_type_id.display_name"/>
                            </h1>
                        </div>

                        <div style="padding: 0 0 20px 0; font-size: 13px;"
                             t-att-dir="'rtl' if o.env.lang == 'ar_001' else 'ltr'">

                            <div class="row mb-1">
                                <div class="col-2">
                                    <strong>Reference:</strong>
                                </div>
                                <div class="col-4">
                                    <span t-field="o.name"/>
                                </div>
                                <div class="col-2">
                                    <strong>Destination Location:</strong>
                                </div>
                                <div class="col-4">
                                    <span t-field="o.location_dest_id.display_name"/>
                                </div>
                            </div>

                            <div class="row mb-1">
                                <div class="col-2">
                                    <strong>Effective Date :</strong>
                                </div>
                                <div class="col-4">
                                    <span t-field="o.date_done" t-options='{"widget": "date"}'/>
                                </div>
                                <div class="col-2">
                                    <strong>Source Document :</strong>
                                </div>
                                <div class="col-4">
                                    <span t-field="o.origin"/>
                                </div>
                            </div>

                            <div class="row mb-1">
                                <div class="col-2">
                                    <strong>Scheduled Date :</strong>
                                </div>
                                <div class="col-4">
                                    <span t-field="o.scheduled_date" t-options='{"widget": "date"}'/>
                                </div>
                                <div class="col-2">
                                    <strong>Contact :</strong>
                                </div>
                                <div class="col-4">
                                    <span t-field="o.partner_id.name"/>
                                </div>
                            </div>
                        </div>

                        <div class="oe_structure"/>

                        <table t-if="o.state != 'done'" class="table table-sm o_main_table"
                               style="border: 1px solid black; table-layout: fixed;"
                               t-att-dir="'rtl' if o.env.lang == 'ar_001' else 'ltr'">
                            <thead>
                                <tr style="background-color: #f2f2f2;">
                                    <th class="text-center" style="border: 1px solid black;">
                                        <strong>Product</strong>
                                    </th>
                                    <th class="text-center" style="border: 1px solid black;">
                                        <strong>UOM</strong>
                                    </th>
                                    <th class="text-center" style="border: 1px solid black;">
                                        <strong>Ordered</strong>
                                    </th>
                                    <th class="text-center" style="border: 1px solid black;">
                                        <strong>Delivered</strong>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="lines" t-value="o.move_ids.filtered(lambda x: x.product_uom_qty)"/>
                                <tr t-foreach="lines" t-as="move">
                                    <td style="border: 1px solid black; vertical-align: middle;" class="text-center">
                                        <span t-field="move.product_id.display_name"/>
                                        <p t-if="move.description_picking" style="font-size: 10px; margin:0;"
                                           t-field="move.description_picking"/>
                                    </td>
                                    <td style="border: 1px solid black; vertical-align: middle;" class="text-center">
                                        <span t-field="move.product_uom.name"/>
                                    </td>
                                    <td style="border: 1px solid black; vertical-align: middle;" class="text-center">
                                        <span t-out="int(move.product_uom_qty)"/>
                                    </td>
                                    <td style="border: 1px solid black; vertical-align: middle;" class="text-center">
                                        <span t-out="int(move.quantity)"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <table t-elif="o.move_line_ids and o.state=='done'" class="table table-sm o_main_table"
                               style="border: 1px solid black; table-layout: fixed;"
                               t-att-dir="'rtl' if o.env.lang == 'ar_001' else 'ltr'">
                            <thead>
                                <tr style="background-color: #f2f2f2;">
                                    <th class="text-center" style="border: 1px solid black;">
                                        <strong>Product</strong>
                                    </th>
                                    <th class="text-center" style="border: 1px solid black;">
                                        <strong>UOM</strong>
                                    </th>
                                    <th class="text-center" style="border: 1px solid black;">
                                        <strong>Ordered</strong>
                                    </th>
                                    <th class="text-center" style="border: 1px solid black;">
                                        <strong>Delivered</strong>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="aggregated_lines"
                                   t-value="o.move_line_ids._get_aggregated_product_quantities()"/>
                                <t t-foreach="aggregated_lines" t-as="line">
                                    <tr>
                                        <td style="border: 1px solid black; vertical-align: middle;"
                                            class="text-center">
                                            <span t-out="aggregated_lines[line]['name']"/>
                                            <p t-if="aggregated_lines[line]['description']"
                                               style="font-size: 10px; margin:0;"
                                               t-out="aggregated_lines[line]['description']"/>
                                        </td>
                                        <td style="border: 1px solid black; vertical-align: middle;"
                                            class="text-center">
                                            <span t-out="aggregated_lines[line]['product_uom'].name"/>
                                        </td>
                                        <td style="border: 1px solid black; vertical-align: middle;"
                                            class="text-center">
                                            <span t-out="int(aggregated_lines[line].get('qty_ordered', 0))"/>
                                        </td>
                                        <td style="border: 1px solid black; vertical-align: middle;"
                                            class="text-center">
                                            <t t-set="qty_done"
                                               t-value="aggregated_lines[line].get('qty_done') or aggregated_lines[line].get('quantity', 0)"/>
                                            <span t-out="int(qty_done)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <div class="oe_structure"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>


