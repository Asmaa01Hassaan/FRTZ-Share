<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_invoice_pricelist" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.invoice.pricelist</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='pricelist_configuration']//div[hasclass('content-group')]/div[hasclass('mt16')]" position="after">
                <div class="row mt16" invisible="not group_product_pricelist">
                    <label for="show_invoice_pricelist" string="Show in Customer Invoice" class="col-lg-4 o_light_label"/>
                    <field name="show_invoice_pricelist"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
