<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_invoice_pricelist" model="ir.ui.view">
        <field name="name">account.move.form.invoice.pricelist</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_left_group']/div[.//field[@name='partner_id']]" position="after">
                <field name="show_invoice_pricelist" invisible="1"/>
                <field name="invoice_pricelist_id"
                       invisible="not show_invoice_pricelist or move_type not in ('out_invoice', 'out_refund', 'out_receipt')"
                       readonly="state != 'draft'"
                       options="{'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
