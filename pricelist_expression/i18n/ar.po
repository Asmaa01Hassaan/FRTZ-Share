#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid "<code>ceil(x)</code> - Round up to next integer"
msgstr "<code>ceil(x)</code> - التقريب لأعلى لأقرب عدد صحيح"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid "<code>cost * 1.2</code> - 20% markup on cost"
msgstr "<code>cost * 1.2</code> - هامش 20٪ على التكلفة"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid "<code>cost</code> - Product standard cost"
msgstr "<code>cost</code> - التكلفة القياسية للمنتج"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid ""
"<code>first_payment</code> - First payment value (from header "
"<code>first_payment_percentage</code>, or line "
"<code>line_first_payment_percentage</code> when scope is Per Lines)"
msgstr ""
"<code>first_payment</code> - قيمة الدفعة الأولى (من الرأس "
"<code>first_payment_percentage</code> أو من السطر "
"<code>line_first_payment_percentage</code> عند النطاق «لكل سطر»)"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid ""
"<code>if(condition, true_value, false_value)</code> - Conditional expression"
" (automatically converted to iff)"
msgstr ""
"<code>if(condition, true_value, false_value)</code> - تعبير شرطي (يُحوَّل "
"تلقائياً إلى iff)"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid ""
"<code>if(installment_num &lt; 12, price, cost)</code> - Use price if "
"installments &lt; 12, else use cost"
msgstr ""
"<code>if(installment_num &lt; 12, price, cost)</code> - استخدم السعر إذا "
"الأقساط &lt; 12 وإلا التكلفة"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid ""
"<code>if(installment_num == 0, price, price * 1.05)</code> - 5% markup for "
"installments"
msgstr ""
"<code>if(installment_num == 0, price, price * 1.05)</code> - هامش 5٪ عند "
"وجود أقساط"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid ""
"<code>if(qty &gt; 10, price * 0.9, price)</code> - 10% discount for quantity"
" &gt; 10"
msgstr ""
"<code>if(qty &gt; 10, price * 0.9, price)</code> - خصم 10٪ للكمية &gt; 10"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid ""
"<code>installment_num</code> - Installment count (from order/invoice header "
"<code>installment_count</code>, or line <code>line_installment_count</code> "
"when scope is Per Lines)"
msgstr ""
"<code>installment_num</code> - عدد الأقساط (من رأس المستند "
"<code>installment_count</code> أو من السطر "
"<code>line_installment_count</code> عند النطاق «لكل سطر»)"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid "<code>price * 1.1</code> - Add 10% markup"
msgstr "<code>price * 1.1</code> - إضافة هامش 10٪"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid "<code>price + (installment_num * 10)</code> - Add $10 per installment"
msgstr "<code>price + (installment_num * 10)</code> - إضافة 10 لكل قسط"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid "<code>price</code> - Base price from pricelist"
msgstr "<code>price</code> - السعر الأساسي من قائمة الأسعار"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid "<code>purchase_price * 1.15</code> - 15% markup on purchase price"
msgstr "<code>purchase_price * 1.15</code> - هامش 15٪ على سعر الشراء"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid "<code>purchase_price</code> - Purchase price (same as cost)"
msgstr "<code>purchase_price</code> - سعر الشراء (مثل التكلفة)"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid "<code>qty</code> - Quantity ordered"
msgstr "<code>qty</code> - الكمية المطلوبة"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid ""
"<code>round(price * 0.9, 2)</code> - 10% discount rounded to 2 decimals"
msgstr "<code>round(price * 0.9, 2)</code> - خصم 10٪ مقرب لمنزلتين"

#. module: pricelist_expression
#: model_terms:ir.ui.view,arch_db:pricelist_expression.view_product_pricelist_item_form_expression
msgid "<code>round(x, n)</code> - Round number x to n decimal places"
msgstr "<code>round(x, n)</code> - تقريب الرقم x إلى n منازل عشرية"

