<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_subscription_period_list" model="ir.ui.view">
        <field name="name">sale.subscription.period.list</field>
        <field name="model">sale.subscription.period</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="interval_number"/>
                <field name="interval_unit"/>
            </list>
        </field>
    </record>

    <record id="view_sale_subscription_period_form" model="ir.ui.view">
        <field name="name">sale.subscription.period.form</field>
        <field name="model">sale.subscription.period</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="interval_number"/>
                        <field name="interval_unit"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sale_subscription_period" model="ir.actions.act_window">
        <field name="name">Billing Periods</field>
        <field name="res_model">sale.subscription.period</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
