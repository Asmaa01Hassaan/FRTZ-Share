<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_generate_subscription_invoices" model="ir.cron">
        <field name="name">Subscription: Generate Recurring Invoices</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_subscription_invoices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_auto_resume_paused_lines" model="ir.cron">
        <field name="name">Subscription: Auto-resume Paused Lines</field>
        <field name="model_id" ref="sale.model_sale_order_line"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_resume_paused_lines()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
