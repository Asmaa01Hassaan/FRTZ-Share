<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_installment_scope_baseline" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.installment.scope.baseline</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='invoicing_settings']" position="inside">
                <setting id="installment_scope_settings"
                         string="Installment Scope"
                         groups="payment_term_installment_extension.group_technical_installments_setting"
                         help="Default scope and how it appears on sales orders, invoices, and payment terms.">
                    <div class="content-group">
                        <div class="row mt16">
                            <label for="installment_default_scope" string="Default Value" class="col-lg-3 o_light_label"/>
                            <field name="installment_default_scope" class="col-lg-4"/>
                        </div>
                        <div class="row mt16">
                            <label for="installment_scope_display" string="On Forms" class="col-lg-3 o_light_label"/>
                            <field name="installment_scope_display" widget="radio" options="{'horizontal': true}" class="col-lg-9"/>
                        </div>
                    </div>
                </setting>
                <setting id="installment_baseline_date_settings"
                         string="Installment Baseline Date"
                         groups="payment_term_installment_extension.group_technical_installments_setting"
                         help="Default baseline date and how it appears on sales orders, invoices, and payment terms.">
                    <div class="content-group">
                        <div class="row mt16">
                            <label for="installment_default_baseline_date" string="Default Value" class="col-lg-3 o_light_label"/>
                            <field name="installment_default_baseline_date" class="col-lg-4"/>
                        </div>
                        <div class="row mt16">
                            <label for="installment_baseline_date_display" string="On Forms" class="col-lg-3 o_light_label"/>
                            <field name="installment_baseline_date_display" widget="radio" options="{'horizontal': true}" class="col-lg-9"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
