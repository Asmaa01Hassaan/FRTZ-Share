<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Overdue Installments List View -->
    <record id="view_overdue_installments_list" model="ir.ui.view">
        <field name="name">account.move.installment.overdue.list</field>
        <field name="model">account.move.installment</field>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <list string="Overdue Installments" create="0"
                  decoration-danger="days_overdue > 30"
                  decoration-warning="days_overdue > 0 and days_overdue &lt;= 30">
                <field name="display_reference"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="move_id"/>
                <field name="product_id" optional="show"/>
                <field name="date_due"/>
                <field name="days_overdue"/>
                <field name="amount_total" sum="Total Due"/>
                <field name="amount_paid" sum="Total Paid"/>
                <field name="amount_residual" sum="Total Remaining"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'partial'"
                       decoration-danger="state == 'overdue'"
                       decoration-success="state == 'paid'"/>
                <field name="is_rescheduled" widget="boolean"/>
                <field name="reschedule_count" optional="hide"/>
                <field name="original_date_due" optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Overdue Installments Search View -->
    <record id="view_overdue_installments_search" model="ir.ui.view">
        <field name="name">account.move.installment.overdue.search</field>
        <field name="model">account.move.installment</field>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <search string="Overdue Installments">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="move_id"/>
                <field name="product_id"/>
                <field name="display_reference"/>
                <filter name="overdue" string="Overdue" domain="[('is_overdue', '=', True)]"/>
                <filter name="overdue_7" string="Overdue &gt; 7 Days"
                        domain="[('days_overdue', '&gt;', 7)]"/>
                <filter name="overdue_30" string="Overdue &gt; 30 Days"
                        domain="[('days_overdue', '&gt;', 30)]"/>
                <filter name="overdue_90" string="Overdue &gt; 90 Days"
                        domain="[('days_overdue', '&gt;', 90)]"/>
                <separator/>
                <filter name="rescheduled" string="Rescheduled"
                        domain="[('is_rescheduled', '=', True)]"/>
                <filter name="not_rescheduled" string="Not Rescheduled"
                        domain="[('is_rescheduled', '=', False)]"/>
                <separator/>
                <filter name="partial" string="Partially Paid"
                        domain="[('state', '=', 'partial')]"/>
                <filter name="unpaid" string="Unpaid"
                        domain="[('amount_paid', '=', 0)]"/>
                <separator/>
                <group expand="1" string="Group By">
                    <filter name="group_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_invoice" string="Invoice" context="{'group_by': 'move_id'}"/>
                    <filter name="group_product" string="Product" context="{'group_by': 'product_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_due_date" string="Due Date" context="{'group_by': 'date_due:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Overdue Installments Pivot View -->
    <record id="view_overdue_installments_pivot" model="ir.ui.view">
        <field name="name">account.move.installment.overdue.pivot</field>
        <field name="model">account.move.installment</field>
        <field name="arch" type="xml">
            <pivot string="Overdue Installments">
                <field name="partner_id" type="row"/>
                <field name="amount_residual" type="measure"/>
                <field name="days_overdue" type="measure"/>
                <field name="amount_total" type="measure"/>
                <field name="amount_paid" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Overdue Installments Graph View -->
    <record id="view_overdue_installments_graph" model="ir.ui.view">
        <field name="name">account.move.installment.overdue.graph</field>
        <field name="model">account.move.installment</field>
        <field name="arch" type="xml">
            <graph string="Overdue Installments" type="bar">
                <field name="partner_id"/>
                <field name="amount_residual" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Overdue Dashboard Action -->
    <record id="action_overdue_installments_dashboard" model="ir.actions.act_window">
        <field name="name">Overdue Installments</field>
        <field name="res_model">account.move.installment</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="domain">[('is_overdue', '=', True)]</field>
        <field name="context">{'search_default_overdue': 1, 'search_default_group_partner': 1}</field>
        <field name="search_view_id" ref="view_overdue_installments_search"/>
    </record>

</odoo>
