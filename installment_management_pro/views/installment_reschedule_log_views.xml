<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Reschedule Log List View -->
    <record id="view_installment_reschedule_log_list" model="ir.ui.view">
        <field name="name">account.installment.reschedule.log.list</field>
        <field name="model">account.installment.reschedule.log</field>
        <field name="arch" type="xml">
            <list string="Reschedule Logs" create="0" edit="0">
                <field name="name" optional="hide"/>
                <field name="create_date" string="Date"/>
                <field name="display_reference"/>
                <field name="partner_id"/>
                <field name="move_id"/>
                <field name="installment_id" optional="hide"/>
                <field name="change_type" widget="badge"
                       decoration-info="change_type == 'date_change'"
                       decoration-warning="change_type == 'amount_change'"
                       decoration-danger="change_type == 'cancel'"
                       decoration-success="change_type == 'split'"/>
                <field name="old_date_due"/>
                <field name="new_date_due"/>
                <field name="old_amount" sum="Old Total" optional="hide"/>
                <field name="new_amount" sum="New Total" optional="hide"/>
                <field name="user_id"/>
                <field name="reason" optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Reschedule Log Form View -->
    <record id="view_installment_reschedule_log_form" model="ir.ui.view">
        <field name="name">account.installment.reschedule.log.form</field>
        <field name="model">account.installment.reschedule.log</field>
        <field name="arch" type="xml">
            <form string="Reschedule Log" create="0" edit="0">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="display_reference"/>
                            <field name="partner_id"/>
                            <field name="installment_id"/>
                            <field name="move_id"/>
                            <field name="change_type"/>
                            <field name="user_id"/>
                            <field name="create_date" string="Date"/>
                        </group>
                        <group string="Changes">
                            <field name="old_date_due"/>
                            <field name="new_date_due"/>
                            <field name="old_amount"/>
                            <field name="new_amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Reschedule Log Search View -->
    <record id="view_installment_reschedule_log_search" model="ir.ui.view">
        <field name="name">account.installment.reschedule.log.search</field>
        <field name="model">account.installment.reschedule.log</field>
        <field name="arch" type="xml">
            <search string="Reschedule Logs">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="move_id"/>
                <field name="installment_id"/>
                <filter name="date_changes" string="Date Changes"
                        domain="[('change_type', '=', 'date_change')]"/>
                <filter name="amount_changes" string="Amount Changes"
                        domain="[('change_type', '=', 'amount_change')]"/>
                <filter name="splits" string="Splits"
                        domain="[('change_type', '=', 'split')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_invoice" string="Invoice" context="{'group_by': 'move_id'}"/>
                    <filter name="group_type" string="Change Type" context="{'group_by': 'change_type'}"/>
                    <filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Reschedule Log Action -->
    <record id="action_installment_reschedule_log" model="ir.actions.act_window">
        <field name="name">Reschedule History</field>
        <field name="res_model">account.installment.reschedule.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_installment_reschedule_log_search"/>
    </record>

</odoo>
