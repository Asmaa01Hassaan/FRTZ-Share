<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_installment_payment" model="ir.ui.view">
        <field name="name">account.payment.form.installment.payment</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group1']/field[@name='date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group[@name='group1']/field[@name='payment_type']" position="before">
               <field name="date" readonly="state != 'draft'"/>
<!--               <field name="person" readonly="state != 'draft'"/>-->

            </xpath>

            <xpath expr="//group[@name='group1']/field[@name='payment_type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group[@name='group2']/field[@name='journal_id']" position="before">
                <field name="payment_type" widget="radio" options="{'horizontal': True}" readonly="1"/>
            </xpath>
            <xpath expr="//group[@name='group2']" position="inside">
                <lable for="payment_scope"/>
                <field name="payment_scope" widget="radio" options="{'horizontal': True}"/>
                <field name="is_dividend_eligible" readonly="state != 'draft'"/>
                <lable for="selected_product_id" invisible="payment_scope != 'by_invoice_lines'"/>
                <field name="unpaid_product_ids" invisible="1"/>
                <field name="selected_product_id"
                       invisible="payment_scope != 'by_invoice_lines'"
                       placeholder="Select a product..."
                       options="{'no_create': True, 'no_create_edit': True}"/>

            </xpath>
            <xpath expr="//notebook[@name='payment_notebook']" position="inside">
                <page string="Transaction" name="transions"
                      invisible="not partner_id">

                    <group>
                        <group>
                            <field name="payment_due_date_filter" string="Due Date"
                                   options="{'datepicker': {'min_date': False}}"
                                   help="This date will be applied to all invoices as due_date_filter"
                                   invisible="1"/>
                        </group>
                        <group>
                            <field name="amount" string="Payment Amount" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="total_control_to_pay"
                                   string="Total Control To Pay"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1"/>
                            <field name="control_payment_remaining_amount"
                                   string="Control Remaining Amount"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1"
                                   style="color: red; font-weight: bold;"
                                   invisible="control_payment_remaining_amount == 0"/>
                        </group>
                    </group>

                    <field name="control_payment_ids" nolabel="1">
                        <list string="Transaction" editable="bottom" create="1" delete="1">
                            <field name="installment_id" column_invisible="1"/>
                            <field name="invoice_line_id" column_invisible="1"/>
                            <field name="installment_reference"
                                   column_invisible="parent.payment_scope not in ('by_all_invoice_lines', 'by_product_invoice')"
                                   string="Transaction" readonly="1"/>
                            <field name="invoice_id"
                                   column_invisible="parent.payment_scope in ('by_all_invoice_lines', 'by_product_invoice')"
                                   required="parent.payment_scope not in ('by_all_invoice_lines', 'by_product_invoice')"
                                   options="{'no_create': True, 'no_create_edit': True}"
                                   string="Transaction"/>
                            <field name="invoice_date" string="Transaction Date" readonly="1"/>
                            <field name="amount_total"
                                   string="Total Amount"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1"/>
                            <field name="total_remaining_amount"
                                   string="Remaining Amount"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1"/>
                            <field name="due_amount"
                                   string="Due Amount"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1"/>
                            <field name="due_date"
                                   string="Due Date"
                                   options="{'datepicker': {'min_date': False}}"
                                   invisible="1"/>
                            <field name="to_pay"
                                   string="To Pay"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                        </list>
                    </field>

                    <group invisible="control_payment_remaining_amount == 0">
                        <div class="alert alert-warning" role="alert">
                            <strong>Warning:</strong>
                            Total control to pay amount must equal the payment amount.
                            Current difference:
                            <field name="control_payment_remaining_amount"
                                   string="Control Remaining Amount"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="1"
                                   nolabel="1"/>
                        </div>
                    </group>

                    <group>
                        <button name="%(action_payment_invoice_wizard)d"
                                string="Pay for Invoices"
                                type="action"
                                class="oe_highlight"
                                icon="fa-list-alt"/>
                    </group>

                    <group invisible="1">
                        <button name="action_process_control_payments"
                                string="Process Control Payments"
                                type="object"
                                class="oe_highlight"
                                icon="fa-money" invisible="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
