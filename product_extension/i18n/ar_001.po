#. module: product_extension
#. odoo-python
#: code:addons/product_extension/models/product_template.py:0
msgid ""
"Internal Reference must be exactly %(length)d characters for category "
"'%(category)s'. Current length: %(current)d"
msgstr ""
"يجب أن يكون المرجع الداخلي %(length)d حرفاً بالضبط للفئة '%(category)s'. "
"الطول الحالي: %(current)d"

#. module: product_extension
#. odoo-python
#: code:addons/product_extension/models/product_template.py:0
msgid ""
"Internal Reference must contain both letters and numbers for category '%s'."
msgstr "يجب أن يحتوي المرجع الداخلي على أحرف وأرقام للفئة '%s'."

#. module: product_extension
#. odoo-python
#: code:addons/product_extension/models/product_template.py:0
