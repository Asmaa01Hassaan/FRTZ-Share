<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_customer_guarantees" model="ir.ui.view">
        <field name="name">account.move.form.customer.guarantees</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="customer_guarantees_list"
                      string="Customer Guarantees List"
                      invisible="move_type not in ('out_invoice', 'out_refund')">
                    <group>
                        <field name="guarantees_count" readonly="1"/>
                        <field name="customer_guarantees_ids" invisible="1"/>
                    </group>
                    <field name="customer_guarantees_list_ids" nolabel="1" readonly="state == 'posted'">
                        <list editable="bottom" create="state != 'posted'" delete="state != 'posted'">
                            <field name="customer_id"/>
                            <field name="sale_order_customer_guarantees_status" readonly="1"/>
                            <field name="date"/>
                            <field name="notes"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
