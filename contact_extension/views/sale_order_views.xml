<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_customer_guarantees" model="ir.ui.view">
        <field name="name">sale.order.form.customer.guarantees</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other_information']" position="after">
                <page name="customer_guarantees_list" string="Customer Guarantees List">
                    <group>
                        <field name="guarantees_count" readonly="1"/>
                    </group>
                    <field name="customer_guarantees_list_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="customer_id"/>
                            <field name="sale_order_customer_guarantees_status" readonly="1"/>
                            <field name="date"/>
                            <field name="notes"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
