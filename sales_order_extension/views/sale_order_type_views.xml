<odoo>
    <record id="view_sale_order_type_tree" model="ir.ui.view">
        <field name="name">sale.order.type.tree</field>
        <field name="model">sale.order.type</field>
        <field name="arch" type="xml">
            <list string="Sale Order Types">
                <field name="company_id" optional="show"/>
                <field name="currency_id" optional="show"/>
                <field name="name"/>
                <field name="product_type"/>
                <field name="sequence_id" optional="show" options="{'no_open': True}" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="view_sale_order_type_form" model="ir.ui.view">
        <field name="name">sale.order.type.form</field>
        <field name="model">sale.order.type</field>
        <field name="arch" type="xml">
            <form string="Sale Order Type">
                <sheet>
                    <field name="active" invisible="1"/>
                    <field name="sequence_auto" invisible="1"/>
                    <field name="action_id" invisible="1"/>
                    <field name="menu_id" invisible="1"/>
                    <group>
                        <field name="company_id"/>
                        <field name="currency_id"/>
                        <field name="name"/>
                        <field name="product_type"/>
                        <field name="sequence_id" readonly="1" options="{'no_open': True}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sale_order_type" model="ir.actions.act_window">
        <field name="name">Sale Order Types</field>
        <field name="res_model">sale.order.type</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>
</odoo>
