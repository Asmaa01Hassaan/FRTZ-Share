<!-- views/menu_views.xml -->
<odoo>
    <!-- Dynamic sale order type menus are created under Sales > Orders -->

    <menuitem id="menu_frtz_root_sales"
              name="Sales Order Types"
              parent="sale.sale_order_menu"
              sequence="35"/>

    <menuitem id="menu_sale_order_type"
              name="Sale Order Type"
              parent="sale.menu_sale_config"
              action="action_sale_order_type"
              sequence="35"/>

    <!-- NOTE: legacy <delete> records for menu_sales_root, menu_frtz_sales_configuration,
         menu_product_parent, menu_products, menu_product_variants, menu_pricelist,
         menu_partner_parent, menu_customers and menu_companies were removed.
         Those XML IDs are no longer defined by this module, so the <delete> tags only
         logged "External ID not found" warnings on every upgrade. Odoo's standard
         orphan-record cleanup already removes such legacy menus when the module is
         updated, so the explicit deletes were redundant. -->
</odoo>
