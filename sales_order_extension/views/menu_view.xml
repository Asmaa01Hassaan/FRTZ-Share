<!-- views/menu_views.xml -->
<odoo>
    <!-- Dynamic sale order type menus are created under Sales > Orders -->

    <menuitem id="menu_frtz_root_sales"
              name="Sales Order Types"
              parent="sale.sale_order_menu"
              sequence="35"/>

    <menuitem id="menu_sale_order_type"
              name="Sale Order Type"
              parent="sale.menu_sale_config"
              action="action_sale_order_type"
              sequence="35"/>

    <!-- Remove legacy top-level FRTZ application menu and duplicate entries -->
    <delete model="ir.ui.menu" id="sales_order_extension.menu_sales_root"/>
    <delete model="ir.ui.menu" id="sales_order_extension.menu_frtz_sales_configuration"/>
    <delete model="ir.ui.menu" id="sales_order_extension.menu_product_parent"/>
    <delete model="ir.ui.menu" id="sales_order_extension.menu_products"/>
    <delete model="ir.ui.menu" id="sales_order_extension.menu_product_variants"/>
    <delete model="ir.ui.menu" id="sales_order_extension.menu_pricelist"/>
    <delete model="ir.ui.menu" id="sales_order_extension.menu_partner_parent"/>
    <delete model="ir.ui.menu" id="sales_order_extension.menu_customers"/>
    <delete model="ir.ui.menu" id="sales_order_extension.menu_companies"/>
</odoo>
