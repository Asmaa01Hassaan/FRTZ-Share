<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_lock_type_from_so" model="ir.ui.view">
        <field name="name">product.template.form.lock.type.from.sale.order</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_general']/field[@name='type']" position="attributes">
                <attribute name="readonly">context.get('sale_order_type_id', False) != False</attribute>
            </xpath>
        </field>
    </record>
</odoo>
