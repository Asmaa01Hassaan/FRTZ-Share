<odoo>
    <record id="account_move_form_invoice_installments" model="ir.ui.view">
        <field name="name">account.move.form.invoice.installments</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Custom fields above payment terms block (anchor: o_td_label before due_date in base view) -->
            <xpath expr="//div[@name='due_date']/preceding-sibling::div[@class='o_td_label'][1]" position="before">
                <field name="payment_type"
                       invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')"/>
                <label for="first_payment_type"
                       invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt') or payment_type != 'regular'"/>
                <div name="first_payment_row" class="o_row"
                     invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt') or payment_type != 'regular'">
                    <field name="first_payment_type" nolabel="1"/>
                    <field name="first_payment_value" nolabel="1"
                           invisible="first_payment_type != 'fixed'"/>
                    <field name="first_payment_percent" nolabel="1"
                           invisible="first_payment_type != 'percent'"/>
                    <span class="align-self-center text-muted"
                          invisible="first_payment_type != 'percent'">%</span>
                </div>
                <field name="installment_count"
                       invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt') or payment_type != 'regular'"/>
            </xpath>

            <!-- Same grid as Invoice Date: label + value row (button beside payment term only) -->
            <xpath expr="//div[@name='due_date']/preceding-sibling::div[@class='o_td_label'][1]" position="replace">
                <label for="invoice_payment_term_id" string="Payment terms"
                       invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')"/>
            </xpath>

            <xpath expr="//div[@name='due_date']" position="replace">
                <!-- o_row + oe_inline: keep external-link button on same line as many2one (no wrap) -->
                <div class="o_row align-items-center o_invoice_payment_term_row"
                     invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')"
                     name="due_date">
                    <field name="invoice_payment_term_id" nolabel="1" class="oe_inline"
                           context="{'example_date': invoice_date, 'example_amount': tax_totals['total_amount_currency']}"
                           placeholder="Payment Terms"
                           options="{'no_quick_create':True}" readonly="state in ['cancel', 'posted']"/>
                    <button name="action_open_invoice_payment_term" type="object"
                            class="btn btn-link p-0"
                            icon="fa-external-link"
                            title="Open payment terms"
                            invisible="payment_type != 'irregular'"/>
                </div>
                <label for="invoice_date_due" string="Due Date"
                       invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')"/>
                <field name="invoice_date_due" nolabel="1" force_save="1" placeholder="Date"/>
            </xpath>
        </field>
    </record>
</odoo>
