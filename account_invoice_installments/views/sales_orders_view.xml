<odoo>
    <!-- Overrides older arch that referenced removed fields; keeps same xml id for DB upgrades -->
    <record id="sale_order_form_type_product_domain" model="ir.ui.view">
        <field name="name">sale.order.form.type.product.domain</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="attributes">
                <attribute name="domain">[('sale_ok', '=', True)]</attribute>
            </xpath>
        </field>
    </record>

    <!-- Add order_type to tree view -->
    <record id="view_order_list_custom" model="ir.ui.view">
        <field name="name">sale.order.list.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_order']" position="after">
                <field name="sale_order_type_id"/>
                <field name="order_type" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Add order_type to form view -->
    <record id="view_order_form_custom" model="ir.ui.view">
        <field name="name">sale.order.form.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- One match only: sale form has several date_order fields; duplicate xpath would duplicate Order Type -->
            <xpath expr="//group[@name='order_details']/field[@name='date_order'][1]" position="before">
                <field name="sale_order_type_id" string="Order Type" options="{'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>
    <record id="sale_order_form_installments" model="ir.ui.view">
        <field name="name">sale.order.form.installments</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//field[@name='payment_term_id']" position="before">
                <field name="payment_type" string="Payment plan"/>
            </xpath>
            <xpath expr="//sheet//field[@name='payment_term_id']" position="attributes">
                <attribute name="invisible">payment_type in ['immediate', 'regular']</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="sale_order_type_name" invisible="1"/>
                <field name="vendor_name_id" string="Vendor Name"
                       invisible="not sale_order_type_name or 'wholesale' not in (sale_order_type_name or '').lower()"/>
            </xpath>

        </field>
    </record>

    <record id="view_sales_order_filter_custom" model="ir.ui.view">
        <field name="name">sale.order.filter.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <!-- Group by Order Type -->
                <filter string="Order Type" name="order_type" context="{'group_by': 'order_type'}"/>
                <filter string="Sale Order Type" name="sale_order_type" context="{'group_by': 'sale_order_type_id'}"/>
            </xpath>

            <!-- Add order_type field to search view -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="order_type" filter_domain="[('order_type','ilike',self)]"/>
                <field name="sale_order_type_id"/>
            </xpath>
        </field>
    </record>
