<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Installment List View -->
    <record id="view_account_move_installment_tree" model="ir.ui.view">
        <field name="name">account.move.installment.list</field>
        <field name="model">account.move.installment</field>
        <field name="arch" type="xml">
            <list string="Installments" decoration-info="state == 'due'" decoration-warning="state == 'partial'" decoration-danger="state == 'overdue'" decoration-success="state == 'paid'">
                <field name="sequence" widget="handle" optional="hide"/>
                <field name="name" optional="hide"/>
                <field name="invoice_line_id" optional="show"/>
                <field name="partner_id" />
                <field name="date_due"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="amount_total" sum="Total"/>
                <field name="amount_paid" sum="Paid" optional="hide"/>
                <field name="amount_residual" sum="Residual" optional="hide"/>
                <field name="state" widget="badge" decoration-info="state == 'due'" decoration-warning="state == 'partial'" decoration-danger="state == 'overdue'" decoration-success="state == 'paid'"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Installment Form View -->
    <record id="view_account_move_installment_form" model="ir.ui.view">
        <field name="name">account.move.installment.form</field>
        <field name="model">account.move.installment</field>
        <field name="arch" type="xml">
            <form string="Installment">
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="sequence"/>
                            <field name="move_id" readonly="1"/>
                            <field name="invoice_line_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="date_due"/>
                            <field name="date_invoice" readonly="1"/>
                            <field name="state" widget="statusbar" statusbar_visible="draft,due,partial,paid"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="amount_total"/>
                            <field name="amount_paid"/>
                            <field name="amount_residual"/>
                        </group>
                        <group>
                            <field name="currency_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="payment_term_line_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Add notes about this installment..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Installment Search View -->
    <record id="view_account_move_installment_search" model="ir.ui.view">
        <field name="name">account.move.installment.search</field>
        <field name="model">account.move.installment</field>
        <field name="arch" type="xml">
            <search string="Installments">
                <field name="name"/>
                <field name="move_id"/>
                <field name="partner_id"/>
                <field name="date_due"/>
                <filter string="Due" name="due" domain="[('state', '=', 'due')]"/>
                <filter string="Overdue" name="overdue" domain="[('state', '=', 'overdue')]"/>
                <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                <filter string="Partially Paid" name="partial" domain="[('state', '=', 'partial')]"/>
                <group expand="0" string="Group By">
                    <filter string="Invoice" name="group_by_move" context="{'group_by': 'move_id'}"/>
                    <filter string="Partner" name="group_by_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Due Date" name="group_by_date" context="{'group_by': 'date_due'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Installment Action -->
    <record id="action_account_move_installment" model="ir.actions.act_window">
        <field name="name">Installments</field>
        <field name="res_model">account.move.installment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_account_move_installment_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No installments found
            </p>
            <p>
                Installments are automatically created from payment terms when is_installment_term is enabled.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_account_move_installment"
              name="Installments"
              parent="sale.sale_menu_root"
              action="action_account_move_installment"
              sequence="35"/>
</odoo>

